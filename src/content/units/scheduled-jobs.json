  "description": "Run code on a schedule and fire events for asynchronous work.",
  "exercises": [
    {
      "id": "sj-001",
      "type": "multiple-choice",
      "prompt": "Which call places a custom event on the event queue?",
      "options": [
        "gs.eventQueue()",
        "gs.fireEvent()",
        "gs.addEvent()",
        "gs.queue()"
      ],
      "correctIndex": 0,
      "xp": 5,
      "difficulty": 2
    },
    {
      "id": "sj-002",
      "type": "assembly",
      "prompt": "Assemble a job that fires a review event for each active incident.",
      "blocks": [
        "var gr = new GlideRecord('incident');",
        "gr.addActiveQuery();",
        "gr.query();",
        "while (gr.next()) {",
        "  gs.eventQueue('incident.review', gr);",
        "}"
      ],
      "correctOrder": [0, 1, 2, 3, 4, 5],
      "xp": 15,
      "difficulty": 3
    },
    {
