      "id": "ag-002",
      "type": "assembly",
      "prompt": "Assemble a query that counts active incidents.",
      "blocks": [
        "var ga = new GlideAggregate('incident');",
        "ga.addQuery('active', true);",
        "ga.addAggregate('COUNT');",
        "ga.query();"
