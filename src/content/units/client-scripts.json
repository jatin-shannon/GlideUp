      "correctIndex": 0,
      "xp": 5,
      "difficulty": 2
    },
    {
      "id": "cs-006",
      "type": "assembly",
      "prompt": "Assemble an onChange script that exits early while the form is still loading.",
      "blocks": [
        "function onChange(control, oldValue, newValue, isLoading) {",
        "  if (isLoading) { return; }",
        "  g_form.setValue('urgency', newValue);",
        "}"
      ],
      "correctOrder": [0, 1, 2, 3],
      "xp": 15,
      "difficulty": 3
    },
    {
      "id": "cs-007",
      "type": "fill-blank",
      "prompt": "Hide the 'impact' field from the form.",
