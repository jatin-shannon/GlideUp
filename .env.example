# Cross-device sync (v1.5). Optional — leave unset and the app runs as the
# fully offline, local-only MVP. Set both to enable Supabase cloud sync.
#
# The publishable key is safe to expose in the client: it only permits access
# through Row Level Security, which restricts every user to their own row.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key_here
